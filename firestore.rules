rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    match /groups/{groupId} {
      // A user may read/update if their uid is in members
      allow read, update: if request.auth != null && request.auth.uid in resource.data.members;
      
      // Creation allowed if creator includes themselves
      allow create: if request.auth != null && request.auth.uid in request.resource.data.members;
      
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
      
      match /settlements/{settlementId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }
    
    match /users/{uid} {
      // a user may read any profile
      allow read: if request.auth != null;
      
      // but write only their own
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
